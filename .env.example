# La Tiendita de Blue — plantilla de variables de entorno.
# Copia este archivo a .env (o .env.local) y completa los valores.
# NUNCA pongas credenciales reales en este archivo (se versiona en git).

# ── Obligatorias ─────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:password@localhost:5432/latiendita_blue?schema=public"
AUTH_SECRET="genera-uno-con:  openssl rand -base64 32"

# ── Recomendadas ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="51999888777"

# ── Seed (npm run db:seed) ───────────────────────────────────
# Contraseñas de los usuarios de ejemplo. Si se dejan vacías, el seed
# genera una contraseña aleatoria por usuario y la imprime en consola.
SEED_ADMIN_PASSWORD=""
SEED_DEMO_PASSWORD=""

# ── Opcionales (activan funcionalidades) ─────────────────────
# Login con Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Pasarela Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=""

# Subida de imágenes a Cloudinary (obligatorio en producción)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Correos transaccionales (Resend)
RESEND_API_KEY=""
EMAIL_FROM=""

# Cron de liberación de stock
CRON_SECRET=""
STOCK_RELEASE_MINUTES="60"
